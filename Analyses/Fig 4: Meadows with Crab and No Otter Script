library(sf)
library(tidyverse)
library(rnaturalearth)
library(ggtext)

# 1. GitHub
otter_url <- "https://raw.githubusercontent.com/Brandothehuman/Senior-Thesis/main/Output/Processed/otter_sightings_cleaned.csv"
crab_url  <- "https://raw.githubusercontent.com/Brandothehuman/Senior-Thesis/main/Output/Processed/crab_sightings_cleaned.csv"
grass_url <- "https://raw.githubusercontent.com/Brandothehuman/Senior-Thesis/main/Output/Processed/seagrass_meadows_cleaned.csv"

# 2. Load Data
otters <- read_csv(otter_url) %>%
  filter(!is.na(Longitude) & !is.na(Latitude)) %>%
  st_as_sf(coords = c("Longitude", "Latitude"), crs = 4326)
seagrass <- read_csv(grass_url) %>%
  filter(!is.na(LONGITUDE) & !is.na(LATITUDE)) %>%
  st_as_sf(coords = c("LONGITUDE", "LATITUDE"), crs = 4326)
crabs <- read_csv(crab_url) %>%
  filter(!is.na(`Longitude (WGS84)`) & !is.na(`Latitude (WGS84)`)) %>%
  st_as_sf(coords = c("Longitude (WGS84)", "Latitude (WGS84)"), crs = 4326)

# 3. Project to British National Grid
otters_p   <- st_transform(otters,   27700)
seagrass_p <- st_transform(seagrass, 27700)
crabs_p    <- st_transform(crabs,    27700)

# 4. Find seagrass meadows that contain crabs (within 100m)
has_crabs_idx      <- st_is_within_distance(seagrass_p, crabs_p, dist = 100, sparse = FALSE)
meadows_with_crabs <- seagrass_p[apply(has_crabs_idx, 1, any), ]
message("Meadows with crabs: ", nrow(meadows_with_crabs))

# 5. Exclude meadows within 19.3 km of an otter
OTTER_RANGE_M   <- 19300
near_otters_idx <- st_is_within_distance(meadows_with_crabs, otters_p, dist = OTTER_RANGE_M, sparse = FALSE)
safe_meadows_p  <- meadows_with_crabs[!apply(near_otters_idx, 1, any), ]
message("Otter-free meadows remaining after filtering: ", nrow(safe_meadows_p))

# 6. Transform back to WGS84
safe_meadows <- st_transform(safe_meadows_p, 4326)

# 7. Create the Map
world <- ne_countries(scale = "medium", returnclass = "sf")

caption_text <- "**Figure 4.**Seagrass meadows (*Zostera marina* / *Zostera noltii*) in Scotland containing green shore crab occurrences within 100 meters and no Eurasian otter occurrences within 19.3 km (maximum reported coastal home range for marine-foraging otters in Scotland)."

ggplot() +
  geom_sf(data = world, fill = "gray95", color = "gray80") +
  geom_sf(data = safe_meadows, color = "chartreuse4", size = 2, shape = 16) +
  coord_sf(xlim = c(-10, 2), ylim = c(54, 61)) +
  theme_minimal(base_family = "serif", base_size = 12) +
  labs(
    title    = NULL,
    subtitle = NULL,
    caption  = caption_text
  ) +
  theme(
    plot.caption          = element_textbox_simple(
                              size   = 12,
                              family = "serif",
                              margin = margin(t = 10),
                              hjust  = 0
                            ),
    plot.caption.position = "plot"
  )
