# 1. Update the Land Mask to High Resolution (Scale 10)
# Note: This might prompt you to install 'rnaturalearthhires'
uk_land <- ne_countries(scale = 10, country = "united kingdom", returnclass = "sf") %>% 
  st_transform(27700) %>% 
  st_union() %>% 
  st_make_valid()

# 2. Manually Define the Grid Extent (Covers all of Scotland & Islands)
# Coordinates in British National Grid (approximate for the whole region)
scotland_extent <- st_bbox(c(xmin = -50000, xmax = 700000, ymin = 500000, ymax = 1250000), 
                           crs = st_crs(27700)) %>% 
  st_as_sfc()

# Create a 2km grid over this larger area
grid <- st_as_stars(scotland_extent, dx = 2000, dy = 2000) %>% st_set_crs(27700)

# 3. Perform IDW
# We use a larger 'nmax' and 'maxdist' to allow the heat to spread to the islands
idw_res <- idw(density ~ 1, target_meadows_p, grid, idp = 2.0, maxdist = 50000)
idw_sf  <- st_as_sf(idw_res) %>% st_make_valid()

# 4. Filter for Ocean
# This removes grid cells that overlap with the high-res UK landmass
ocean_idw <- idw_sf[st_disjoint(idw_sf, uk_land, sparse = FALSE), ]
ocean_idw_4326 <- st_transform(ocean_idw, 4326)

# 5. Mapping with expanded limits
world <- ne_countries(scale = 10, returnclass = "sf")

ggplot() +
  geom_sf(data = world, fill = "gray95", color = "gray80") +
  # Heatmap
  geom_sf(data = ocean_idw_4326, aes(fill = var1.pred), color = NA, alpha = 0.8) +
  scale_fill_viridis_c(option = "inferno", name = "Overlap Intensity", na.value = "transparent") +
  # Visualizing the meadows to see where data is coming from
  geom_sf(data = st_transform(target_meadows_p, 4326), color = "cyan", size = 0.3) +
  # Expanded View: Specifically focused on Scotland and its islands
  coord_sf(xlim = c(-9, 1), ylim = c(54, 61), expand = FALSE) + 
  theme_minimal() +
  labs(title = "Scotland Species Overlap Heatmap",
       subtitle = "High-resolution marine masking for coastal islands")
