library(sf)
library(tidyverse)
library(rnaturalearth)

# 1. Load and Clean Data
otters <- read.csv("otter_sightings.csv") %>%
  filter(!is.na(Longitude) & !is.na(Latitude)) %>%
  st_as_sf(coords = c("Longitude", "Latitude"), crs = 4326)

seagrass <- read.csv("seagrass_meadows.csv") %>%
  filter(!is.na(LONGITUDE) & !is.na(LATITUDE)) %>%
  st_as_sf(coords = c("LONGITUDE", "LATITUDE"), crs = 4326)

# 2. Project to British National Grid (EPSG: 27700)
# This allows us to calculate distances in meters accurately
otters_projected <- st_transform(otters, 27700)
seagrass_projected <- st_transform(seagrass, 27700)

# 3. Find Overlaps (5 miles = 8046.72 meters)
distance_threshold <- 5 * 1609.34

# This finds otter points that are within 5 miles of ANY seagrass point
overlap_logical <- st_is_within_distance(otters_projected, seagrass_projected, 
                                         dist = distance_threshold, 
                                         sparse = FALSE)

# Filter the otter dataset to only include those near seagrass
# apply(..., 1, any) checks if a row has at least one 'TRUE' (near a seagrass meadow)
otters_near_seagrass <- otters[apply(overlap_logical, 1, any), ]

# 4. Create the Map
world <- ne_countries(scale = "medium", returnclass = "sf")

ggplot() +
  # Background Map
  geom_sf(data = world, fill = "gray95", color = "gray80") +
  
  # Layer 1: All Seagrass (as a light green area)
  geom_sf(data = seagrass, color = "seagreen", size = 0.5, alpha = 0.2) +
  
  # Layer 2: All Otters (as light blue dots)
  geom_sf(data = otters, color = "steelblue", size = 0.5, alpha = 0.2) +
  
  # Layer 3: THE OVERLAP (Red Pins)
  geom_sf(data = otters_near_seagrass, color = "red", size = 1.5, shape = 18) +
  
  # Focus on the relevant area
  coord_sf(xlim = c(-9, 1), ylim = c(54, 61)) +
  theme_minimal() +
  labs(title = "Otter Sightings within 5 Miles of Seagrass Meadows",
       subtitle = "Red diamonds indicate overlap areas",
       caption = "Distance calculated using EPSG:27700")
