library(sf)
library(tidyverse)
library(rnaturalearth)

# 1. Load and prepare all three datasets
# Otters: Longitude / Latitude
otters <- read.csv("otter_sightings.csv", check.names = FALSE) %>%
  filter(!is.na(Longitude) & !is.na(Latitude)) %>%
  st_as_sf(coords = c("Longitude", "Latitude"), crs = 4326)

# Seagrass: LONGITUDE / LATITUDE
seagrass <- read.csv("seagrass_meadows.csv", check.names = FALSE) %>%
  filter(!is.na(LONGITUDE) & !is.na(LATITUDE)) %>%
  st_as_sf(coords = c("LONGITUDE", "LATITUDE"), crs = 4326)

# Crabs: Longitude (WGS84) / Latitude (WGS84)
crabs <- read.csv("crab_sightings.csv", check.names = FALSE) %>%
  filter(!is.na(`Longitude (WGS84)`) & !is.na(`Latitude (WGS84)`)) %>%
  st_as_sf(coords = c("Longitude (WGS84)", "Latitude (WGS84)"), crs = 4326)

# 2. Project to British National Grid (EPSG: 27700) for distance adjusment from meters
otters_p <- st_transform(otters, 27700)
seagrass_p <- st_transform(seagrass, 27700)
crabs_p <- st_transform(crabs, 27700)

# 3. STEP 1: Find seagrass meadows containing shorecrabs
# 100-meter co-location buffer
seagrass_with_crabs_idx <- st_is_within_distance(seagrass_p, crabs_p, dist = 100, sparse = FALSE)
seagrass_with_crabs <- seagrass_p[apply(seagrass_with_crabs_idx, 1, any), ]

# 4. STEP 2: Filter those for otters within 9 miles (14,484 meters)
dist_9_miles <- 9 * 1609.34
final_idx <- st_is_within_distance(seagrass_with_crabs, otters_p, dist = dist_9_miles, sparse = FALSE)
target_meadows <- seagrass_with_crabs[apply(final_idx, 1, any), ]

# 5. Create the Map
world <- ne_countries(scale = "medium", returnclass = "sf")

ggplot() +
  geom_sf(data = world, fill = "gray95", color = "gray80") +
  
  # Background: All seagrass meadows (very faint)
  geom_sf(data = seagrass, color = "seagreen", size = 0.3, alpha = 0.1) +
  
  # RESULTS: Only meadows meeting both criteria
  geom_sf(data = target_meadows, color = "darkgreen", size = 2, shape = 16) +
  
  coord_sf(xlim = c(-10, 2), ylim = c(54, 61)) +
  theme_minimal() +
  labs(title = "Targeted Seagrass Meadows",
       subtitle = "Seagrass ,eadows containing shorecrabs with an otter sighting within 9 miles",
       caption = "Green points indicate meadows meeting both criteria")
